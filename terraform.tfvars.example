resource_group_name        = ""
aks_cluster_name           = ""
azure_subscription_id      = ""

# Falcon API Credentials
falcon_client_id           = "your-client-id"
falcon_client_secret       = "your-client-secret"

# Sensor Pull Token
# ./falcon-container-sensor-pull.sh -u $ID -s $SECRET --type falcon-sensor --platform x86_64 --get-pull-token
falcon_registry_pull_token = "YOUR_SENSOR_PULL_TOKEN"

# KAC Pull Token
# ./falcon-container-sensor-pull.sh -u $ID -s $SECRET --type falcon-kac --platform x86_64 --get-pull-token
falcon_kac_pull_token      = "YOUR_KAC_PULL_TOKEN"

# IAR Pull Token
# ./falcon-container-sensor-pull.sh -u $ID -s $SECRET --type falcon-imageanalyzer --platform x86_64 --get-pull-token
falcon_iar_pull_token      = "YOUR_IAR_PULL_TOKEN"

# Falcon Configuration
falcon_cid                 = ""
falcon_cloud_region        = "us-1"
falcon_platform_version    = ""

# Component Versions
falcon_sensor_version      = "7.35.0-18803-1"
falcon_kac_version         = "7.36.0-3401"
falcon_iar_version         = "1.0.23"

falcon_tags                = "env:production,cloud:azure"
