resource_group_name        = "TedsAKS_group"
aks_cluster_name           = "TedsAKS-10"
azure_subscription_id      = "5a84cb53-b383-44db-bd58-c65ca3dfcb8c"

falcon_client_id           = "your-client-id"
falcon_client_secret       = "your-client-secret"

# Generate each token with the correct --type flag:
# Sensor: ./falcon-container-sensor-pull.sh -u $ID -s $SECRET --type falcon-sensor --platform x86_64 --get-pull-token
falcon_registry_pull_token = "YOUR_SENSOR_PULL_TOKEN"

# KAC: ./falcon-container-sensor-pull.sh -u $ID -s $SECRET --type falcon-kac --platform x86_64 --get-pull-token
falcon_kac_pull_token      = "YOUR_KAC_PULL_TOKEN"

# IAR: ./falcon-container-sensor-pull.sh -u $ID -s $SECRET --type falcon-imageanalyzer --platform x86_64 --get-pull-token
falcon_iar_pull_token      = "YOUR_IAR_PULL_TOKEN"

falcon_cid                 = "58FC9E1DDE9946D4976B66844B4B15F6-D3"
falcon_cloud_region        = "us-1"
falcon_platform_version    = ""

falcon_sensor_version      = "7.35.0-18803-1"
falcon_kac_version         = "7.36.0-3401"
falcon_iar_version         = "1.0.23"

falcon_tags                = "env:production,cloud:azure,cluster:TedsAKS-10"
